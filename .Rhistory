logLik.AdPaik <- function(object, ...) {
# Extract log likelihood
out <- object$Loglikelihood
# Check if the number of parameters exists
if (!is.null(object$NParameters)) {
# Assign degrees of freedom (df) attribute
attr(out, "df") <- object$NParameters
} else {
# Assign class for logLik if NParameters is not found
class(out) <- 'logLik'
}
return(out)
}
logLik(result)
result$OptimalParameters
length(result$OptimalParameters)
logLik.AdPaik <- function(object, ...) {
out <- object$Loglikelihood
if (!is.null(result$NParameters)) attr(out, "df") <- result$NParameters
else attr(out, "df") <- length(result$OptimalParameters)
class(out) <- 'logLik'
out
}
